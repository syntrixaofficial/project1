# Copy to .env.n8n for n8n runtime environment.
# These values assume n8n, dashboard-api, and NemoClaw/OpenClaw share the
# `syntrixa` Docker network. Use service names, not localhost, between containers.

N8N_ENCRYPTION_KEY=replace-with-a-32-plus-character-random-key
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
DASHBOARD_INGEST_TOKEN=replace-with-a-long-random-token

OPENCLAW_AGENT_INVOKE_URL=http://nemoclaw:8990/openclaw/agent/invoke
API_HEALTH_URL=http://nemoclaw:8990/openclaw/health
PUBLIC_INTEL_PROXY_URL=http://nemoclaw:8990/internal/public-intelligence
MARKETING_ANALYTICS_PROXY_URL=http://nemoclaw:8990/internal/marketing-analytics
INFRA_MONITORING_PROXY_URL=http://nemoclaw:8990/internal/infra-health
DOCKER_HEALTH_PROXY_URL=http://nemoclaw:8990/internal/docker-health
VPS_MONITORING_PROXY_URL=http://nemoclaw:8990/internal/vps-monitoring
DASHBOARD_API_EVENT_URL=http://dashboard-api:8080/api/n8n/events
DASHBOARD_API_CANDIDATE_URL=http://dashboard-api:8080/api/n8n/request-candidates

N8N_PUBLIC_WEBHOOK_URL=http://127.0.0.1:5678/
GENERIC_TIMEZONE=Asia/Calcutta
SYNTRIXA_FROM_EMAIL=agents@syntrixa.internal

POSTGRES_DB=syntrixa
POSTGRES_USER=syntrixa
POSTGRES_PASSWORD=syntrixa-local-postgres
MONGO_INITDB_ROOT_USERNAME=syntrixa
MONGO_INITDB_ROOT_PASSWORD=syntrixa-local-mongo
MONGO_INITDB_DATABASE=syntrixa

# Optional live connector credentials. Blank values keep workflows in safe staging mode.
LINKEDIN_ACCESS_TOKEN=
X_ACCESS_TOKEN=
META_ACCESS_TOKEN=
SMTP_HOST=
RESEND_API_KEY=
