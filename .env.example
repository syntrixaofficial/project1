# Copy to .env for local/container runtime secrets.
# Never commit real secrets.

# OpenClaw gateway token used by the container runtime.
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_INVOKE_HOST=0.0.0.0
OPENCLAW_INVOKE_PORT=8990
OPENCLAW_WORKSPACE_DIR=/workspace/openclaw-workspace

# Custom Syntrixa OS dashboard.
DASHBOARD_API_HOST=0.0.0.0
DASHBOARD_API_PORT=8080
DASHBOARD_ALLOWED_ORIGIN=http://127.0.0.1:5173
OPENCLAW_BASE_URL=http://nemoclaw:8990
DASHBOARD_STATE_FILE=/app/data/dashboard-state.json
DASHBOARD_INGEST_TOKEN=replace-with-a-long-random-token
N8N_INTENT_WEBHOOK_URL=http://n8n:5678/webhook/openclaw/intent/
DASHBOARD_API_EVENT_URL=http://dashboard-api:8080/api/n8n/events
DASHBOARD_API_CANDIDATE_URL=http://dashboard-api:8080/api/n8n/request-candidates

# NemoClaw fixed ports and security defaults.
NEMOCLAW_GATEWAY_PORT=8990
NEMOCLAW_DASHBOARD_PORT=18789
NEMOCLAW_POLICY_TIER=restricted
NEMOCLAW_SANDBOX_NAME=syntrixa-openclaw
NEMOCLAW_SANDBOX_GPU=0
NEMOCLAW_PROVIDER=custom
NEMOCLAW_ENDPOINT_URL=http://127.0.0.1:8000/v1
NEMOCLAW_MODEL=syntrixa-security-stub
COMPATIBLE_API_KEY=dummy
NEMOCLAW_PREFERRED_API=openai-completions

# Optional if you later choose NVIDIA Endpoints as the model provider.
NVIDIA_API_KEY=
NEMOCLAW_PROVIDER_KEY=

# Future n8n webhook/auth material.
N8N_ENCRYPTION_KEY=replace-with-a-32-plus-character-random-key
N8N_OPENCLAW_WEBHOOK_SECRET=replace-with-a-long-random-token
N8N_PUBLIC_WEBHOOK_URL=http://127.0.0.1:5678/
GENERIC_TIMEZONE=Asia/Calcutta

# n8n workflow runtime URLs used by newn8n.json.
# Defaults assume n8n, the dashboard backend, and NemoClaw/OpenClaw share the
# `syntrixa` Docker network. Use service names, not localhost, between containers.
OPENCLAW_AGENT_INVOKE_URL=http://nemoclaw:8990/openclaw/agent/invoke
PUBLIC_INTEL_PROXY_URL=http://nemoclaw:8990/internal/public-intelligence
MARKETING_ANALYTICS_PROXY_URL=http://nemoclaw:8990/internal/marketing-analytics
API_HEALTH_URL=http://nemoclaw:8990/openclaw/health
INFRA_MONITORING_PROXY_URL=http://nemoclaw:8990/internal/infra-health
DOCKER_HEALTH_PROXY_URL=http://nemoclaw:8990/internal/docker-health
VPS_MONITORING_PROXY_URL=http://nemoclaw:8990/internal/vps-monitoring
SYNTRIXA_FROM_EMAIL=agents@syntrixa.internal

# Local operational stores used by imported n8n credentials.
# These defaults match the local n8n credentials file for Docker development only.
POSTGRES_DB=syntrixa
POSTGRES_USER=syntrixa
POSTGRES_PASSWORD=syntrixa-local-postgres
MONGO_INITDB_ROOT_USERNAME=syntrixa
MONGO_INITDB_ROOT_PASSWORD=syntrixa-local-mongo
MONGO_INITDB_DATABASE=syntrixa

# Optional production connector credentials.
# Leave blank locally; n8n will stage campaign/social/email actions for human approval.
LINKEDIN_ACCESS_TOKEN=
X_ACCESS_TOKEN=
META_ACCESS_TOKEN=
SMTP_HOST=
RESEND_API_KEY=

# Future LLM/provider keys. Keep blank until intentionally configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Per-agent model routing.
# Use shared provider keys above when possible, or set an agent-specific key below.
# Never commit real key values.
SYNTRA_MODEL_PROVIDER=
SYNTRA_MODEL_NAME=
SYNTRA_MODEL_ENDPOINT_URL=
SYNTRA_MODEL_API_KEY=

LEAD_QUALIFICATION_MODEL_PROVIDER=
LEAD_QUALIFICATION_MODEL_NAME=
LEAD_QUALIFICATION_MODEL_ENDPOINT_URL=
LEAD_QUALIFICATION_MODEL_API_KEY=

RESEARCH_MODEL_PROVIDER=
RESEARCH_MODEL_NAME=
RESEARCH_MODEL_ENDPOINT_URL=
RESEARCH_MODEL_API_KEY=

HELPDESK_MODEL_PROVIDER=
HELPDESK_MODEL_NAME=
HELPDESK_MODEL_ENDPOINT_URL=
HELPDESK_MODEL_API_KEY=

MARKETING_SALES_MODEL_PROVIDER=
MARKETING_SALES_MODEL_NAME=
MARKETING_SALES_MODEL_ENDPOINT_URL=
MARKETING_SALES_MODEL_API_KEY=

HEALTH_MONITORING_MODEL_PROVIDER=
HEALTH_MONITORING_MODEL_NAME=
HEALTH_MONITORING_MODEL_ENDPOINT_URL=
HEALTH_MONITORING_MODEL_API_KEY=
